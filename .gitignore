# Global blacklist: ignore everything, except directories.
*
!*/

# Per-directory whitelists.

# root
!/.gitignore
!/LICENSE
!/README.md
!/AGENTS.md
!/.rumdl.toml
!/build.gradle.kts
!/settings.gradle.kts
!/gradle.properties
!/gradlew

# docs
!/docs/**/*.md

# host-side python tests
!/tests/python/*.py
!/tests/python/requirements.txt

# gradle wrapper
!/gradle/wrapper/gradle-wrapper.jar
!/gradle/wrapper/gradle-wrapper.properties

# app module
!/app/build.gradle.kts
!/app/src/main/AndroidManifest.xml

# android resources
!/app/src/main/res/**/*.xml

# kotlin source
!/app/src/main/java/**/*.kt
!/app/src/androidTest/java/**/*.kt

# python source
!/app/src/main/python/**/*.py
!/app/src/main/python/**/*.xsl
!/app/src/main/python/**/*.css
!/app/src/main/python/**/*.tmpl
!/app/src/main/python/**/*.html
!/app/src/main/python/**/*.xhtml
!/app/src/main/python/**/*.json
!/app/src/main/python/**/*.types

# fdroid metadata
!/metadata/**/*.yml

# fastlane metadata
!/fastlane/metadata/**/*.jpg
!/fastlane/metadata/**/*.png
!/fastlane/metadata/**/*.txt

# github actions
!/.github/workflows/release.yml
!/.github/workflows/ci.yml
